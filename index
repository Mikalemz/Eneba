<!DOCTYPE html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Eneba Clone - Home</title>
    <link rel="stylesheet" href="style.css" />
  </head>
  <body>
    <header class="header">
      <div class="container">
        <div class="logo">ENEBA CLONE</div>

        <div class="search-container">
          <input type="text" placeholder="Search for fun games..." />
          <button type="button">Search</button>
        </div>

        <nav class="nav-auth">
          <a href="#">Store</a>
          <a href="#">Login</a>
        </nav>
      </div>
    </header>

    <main class="main-content">
      <section class="hero-section">
        <div class="hero-overlay">
          <h1>Discover your next adventure</h1>
          <p>
            Thousands of games for PC, PlayStation, Xbox and Nintendo at
            incredible prices.
          </p>
          <a href="#" class="btn-explore">Explore Store →</a>
        </div>
      </section>

      <section class="categories-section">
        <h2>Popular Categories</h2>
        <div class="categories-grid">
          <div class="category-item">PC Games</div>
          <div class="category-item">PlayStation</div>
          <div class="category-item">Xbox</div>
          <div class="category-item">Nintendo</div>
        </div>
      </section>

      <section class="offers-section">
        <h2>Featured Offers</h2>
        <div class="products-grid">
          <article class="product-card">
            <div class="card-header">
              <span class="badge-discount">-15%</span>
              <span class="badge-platform">XBOX</span>
            </div>

            <div class="product-image">
              <img src="img/forza.jpg" alt="Forza Horizon 5" />
            </div>

            <div class="product-info">
              <h3>Forza Horizon 5</h3>
              <div class="price-wrapper">
                <span class="price-old">39.99€</span>
                <span class="price-current">33.99€</span>
              </div>
            </div>
          </article>

          <article class="product-card">
            <div class="card-header">
              <span class="badge-discount">-50%</span>
              <span class="badge-platform">PC</span>
            </div>
            <div class="product-image">
              <img src="img/cyberpunk.jpg" alt="Cyberpunk 2077" />
            </div>
            <div class="product-info">
              <h3>Cyberpunk 2077</h3>
              <div class="price-wrapper">
                <span class="price-old">29.99€</span>
                <span class="price-current">14.99€</span>
              </div>
            </div>
          </article>
        </div>
      </section>
    </main>

    <footer class="footer">
      <div class="container">
        <p>&copy; 2026 Eneba Clone MVP. Proyecto Educativo.</p>
      </div>
    </footer>
  </body>
</html>
